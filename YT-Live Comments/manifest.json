{
  "manifest_version": 3,
  "name": "YouTube Video Archiver",
  "description": "Archive YouTube videos with metadata, comments, live chat, and video files. Generates a YouTube-clone HTML viewer.",
  "version": "2.1.3",
  "permissions": ["storage", "downloads", "sidePanel", "activeTab", "nativeMessaging", "offscreen"],
  "host_permissions": ["https://www.youtube.com/*", "https://*.googlevideo.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YouTube Video Archiver",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/page-bridge.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
